<?xml version="1.0" encoding="utf-8"?>
<!-- Regole per l'estrazione dati — disabilitiamo il backup cloud -->
<data-extraction-rules xmlns:tools="http://schemas.android.com/tools">
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
